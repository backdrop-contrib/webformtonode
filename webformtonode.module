<?php

/**
 * @file
 * Core hooks and AJAX "Warp Engine" for Webform to Node.
 */

/**
 * Implements hook_config_info().
 */
function webformtonode_config_info() {
  $prefixes['webformtonode.settings'] = array(
    'label' => t('Webform to node settings'),
    'group' => t('Configuration'),
  );
  return $prefixes;
}

/**
 * Implements hook_menu().
 */
function webformtonode_menu() {
  $items = array();

  $items['admin/config/webformtonode/settings'] = array(
    'title' => 'Webform to node',
    'page callback' => 'webformtonode_admin_settings_landing',
    'access arguments' => array('administer site configuration'),
    'file' => 'webformtonode.admin.inc',
  );

  $items['admin/config/webformtonode/settings/select_webforms'] = array(
    'title' => 'Manage webform selection',
    'page callback' => 'backdrop_get_form',
    'page arguments' => array('webformtonode_admin_select_form'),
    'access arguments' => array('administer site configuration'),
    'type' => MENU_NORMAL_ITEM,
    'file' => 'webformtonode.admin.inc',
  );

  $items['admin/config/webformtonode/settings/select_webforms/confirm'] = array(
    'title' => 'Confirm Deletion',
    'page callback' => 'backdrop_get_form',
    'page arguments' => array('webformtonode_admin_select_confirm_form'),
    'access arguments' => array('administer site configuration'),
    'type' => MENU_CALLBACK,
    'file' => 'webformtonode.admin.inc',
  );

  $items['admin/config/webformtonode/settings/manage_webforms/fields/%'] = array(
    'title' => 'Configure Webform Mapping',
    'page callback' => 'backdrop_get_form',
    'page arguments' => array('webformtonode_admin_fields_list_form', 6),
    'access arguments' => array('administer site configuration'),
    'type' => MENU_CALLBACK,
    'file' => 'webformtonode.admin.inc',
  );

  $items['admin/config/webformtonode/settings/manage_webforms/fields/%/confirm-change'] = array(
    'title' => 'Confirm Mapping Change',
    'page callback' => 'backdrop_get_form',
    'page arguments' => array('webformtonode_admin_change_type_confirm_form', 6),
    'access arguments' => array('administer site configuration'),
    'type' => MENU_CALLBACK,
    'file' => 'webformtonode.admin.inc',
  );

  $items['node/%webform_menu/submission/%webform_menu_submission/saveasnode'] = array(
    'title' => 'Save as Node',
    'load arguments' => array(1),
    'page callback' => 'webformtonode_confirm_callback',
    'page arguments' => array(1, 3),
    'access callback' => 'webform_results_access',
    'access arguments' => array(1),
    'type' => MENU_CALLBACK,
  );

  return $items;
}

/**
 * AJAX Wrapper for the "Save as Node" confirmation.
 */
function webformtonode_confirm_callback($node, $submission) {
  $is_ajax = (isset($_GET['ajax']) && $_GET['ajax'] == 1) || backdrop_is_ajax();

  if ($is_ajax) {
    $form = backdrop_get_form('webformtonode_confirm', $node, $submission);
    $commands = array();
    $commands[] = ajax_command_open_dialog(
      '#backdrop-modal',
      t('Promote Submission #@serial', array('@serial' => $submission->serial)),
      backdrop_render($form),
      array('width' => 500)
    );
    return array('#type' => 'ajax', '#commands' => $commands);
  }

  return backdrop_get_form('webformtonode_confirm', $node, $submission);
}

/**
 * Implements hook_webform_submission_actions().
 */
function webformtonode_webform_submission_actions($node, $submission) {
  $enabled_nids = config_get('webformtonode.settings', 'webforms') ?: array();
  $actions = array();

  if (webform_results_access($node) && in_array($node->nid, $enabled_nids)) {
    $existing_nid = db_query("SELECT nid FROM {webformtonode_map} WHERE sid = :sid", array(':sid' => $submission->sid))->fetchField();

    if ($existing_nid) {
      $actions['saveasnode'] = array(
        'title' => '✅ ' . t('Already saved as Node #@nid', array('@nid' => $existing_nid)),
        'href' => 'node/' . $existing_nid,
      );
    }
    else {
      backdrop_add_library('system', 'backdrop.ajax');
      backdrop_add_library('system', 'backdrop.dialog');
      $actions['saveasnode'] = array(
        'title' => t('Save as node'),
        'href' => 'node/' . $node->nid . '/submission/' . $submission->sid . '/saveasnode',
        'attributes' => array('class' => array('use-ajax')),
      );
    }
  }
  return $actions;
}

/**
 * The Confirmation Form builder.
 */
function webformtonode_confirm($form, &$form_state, $node, $submission) {
  $form['#node'] = $node;
  $form['#submission'] = $submission;

  $form['description'] = array(
    '#markup' => '<p>' . t('Are you sure you want to save submission #@serial as a node?', array('@serial' => $submission->serial)) . '</p>',
  );

  $form['actions'] = array('#type' => 'actions');
  $form['actions']['submit_save'] = array(
    '#type' => 'submit',
    '#value' => t('Save'),
    '#ajax' => array('progress' => array('type' => 'throbber')),
  );

  $form['actions']['submit_edit'] = array(
    '#type' => 'submit',
    '#value' => t('Save and Edit'),
    '#ajax' => array('progress' => array('type' => 'throbber')),
  );

  $form['actions']['cancel'] = array(
    '#type' => 'button',
    '#value' => t('Cancel'),
    '#ajax' => array('callback' => 'webformtonode_ajax_close_modal'),
  );

  return $form;
}

/**
 * Submit function for creating a node from a webform submission.
 */
function webformtonode_confirm_submit($form, &$form_state) {
  $submission = $form['#submission'];
  $webform_node = $form['#node'];

  $exists = db_query("SELECT nid FROM {webformtonode_map} WHERE sid = :sid", array(':sid' => $submission->sid))->fetchField();
  if ($exists) {
    backdrop_set_message(t('Already promoted to Node #@nid.', array('@nid' => $exists)), 'warning');
    return;
  }

  $config = config('webformtonode.settings');
  $target_type = $config->get('mapping_' . $webform_node->nid . '_type');
  $field_map = $config->get('mapping_' . $webform_node->nid . '_fields');

  if (!$target_type || empty($field_map)) {
    backdrop_set_message(t('No mapping found.'), 'error');
    return;
  }

  webformtonode_augment_submission($submission);
  $new_node = entity_create('node', array('type' => $target_type));
  node_object_prepare($new_node);
  $new_node->uid = $submission->uid;

  $status_setting = config_get('webformtonode.settings', 'node_status_' . $webform_node->nid);
  $new_node->status = ($status_setting !== NULL) ? (int) $status_setting : 1;

  // --- THE NUCLEAR FIX MAPPING LOOP ---
  foreach ($field_map as $webform_key => $node_target) {
    if (empty($node_target) || !isset($submission->keyed_data[$webform_key])) { continue; }

    $values = array_filter($submission->keyed_data[$webform_key], function($val) {
      return ($val !== '' && $val !== NULL);
    });

    if (empty($values)) { continue; }

    $field_info = field_info_field($node_target);
    $column = 'value';
    if (isset($field_info['type'])) {
      switch ($field_info['type']) {
        case 'link_field': $column = 'url'; break;
        case 'email': $column = 'email'; break;
        case 'taxonomy_term_reference': $column = 'tid'; break;
        case 'file':
        case 'image': $column = 'fid'; break;
      }
    }

    $field_data = array();
    foreach ($values as $delta => $val) {
      if ($node_target == 'title') { $new_node->title = $val; continue; }

      $item = array();
      if (isset($field_info['type']) && ($field_info['type'] == 'file' || $field_info['type'] == 'image')) {
        $new_fid = _webformtonode_copy_file($val, $new_node, $node_target);
        if ($new_fid) { $item = array('fid' => $new_fid, 'display' => 1); }
      }
      elseif ($node_target == 'body') { $item = array('value' => $val, 'format' => 'filtered_html'); }
      else { $item = array($column => $val); }

      if (!empty($item)) { $field_data[LANGUAGE_NONE][$delta] = $item; }
    }

    if (!empty($field_data)) { $new_node->{$node_target} = $field_data; }
  }

  if (empty($new_node->title)) {
    $new_node->title = t('@form Submission @serial', array('@form' => $webform_node->title, '@serial' => $submission->serial));
  }

  node_save($new_node);

  // Source of Truth: Record in our Map table.
  db_insert('webformtonode_map')->fields(array('sid' => $submission->sid, 'nid' => $new_node->nid, 'created' => REQUEST_TIME))->execute();

  backdrop_set_message(t('Node created: !link', array('!link' => l($new_node->title, 'node/' . $new_node->nid))));

  $clicked = $form_state['clicked_button']['#array_parents'][1];
  $path = ($clicked == 'submit_edit') ? "node/{$new_node->nid}/edit" : "node/{$webform_node->nid}/webform-results";

  if (backdrop_is_ajax()) {
    $commands = array();
    $commands[] = ajax_command_close_dialog('#backdrop-modal');
    $commands[] = ajax_command_redirect(url($path, array('absolute' => TRUE)));
    print ajax_render($commands);
    backdrop_exit();
  }
  $form_state['redirect'] = $path;
}

/**
 * Implements hook_views_data().
 * Exposes the webformtonode_map table with all raw fields and helpers.
 */
function webformtonode_views_data() {
  $data = array();

  $data['webformtonode_map']['table']['group'] = t('Webform to Node');

  // Join to webform_submissions so our fields appear in Submission views.
  $data['webformtonode_map']['table']['join'] = array(
    'webform_submissions' => array(
      'left_field' => 'sid',
      'field' => 'sid',
    ),
  );

  // 1. RAW NID FIELD (Essential for custom "Edit" links/buttons)
  $data['webformtonode_map']['nid'] = array(
    'title' => t('Promoted Node ID'),
    'help' => t('The raw ID of the node created from this submission.'),
    'field' => array(
      'handler' => 'views_handler_field_numeric',
      'click sortable' => TRUE,
    ),
    'filter' => array('handler' => 'views_handler_filter_numeric'),
    'sort' => array('handler' => 'views_handler_sort'),
    // Relationship remains so you can also pull in Title/Author/etc.
    'relationship' => array(
      'base' => 'node',
      'base field' => 'nid',
      'handler' => 'views_handler_relationship',
      'label' => t('Promoted Node'),
    ),
  );

  // 2. PROMOTION STATUS (The Boolean Helper)
  $data['webformtonode_map']['nid_status'] = array(
    'title' => t('Promotion Status'),
    'help' => t('Shows "Promoted" or "Not Saved" based on whether a map exists.'),
    'real field' => 'nid',
    'field' => array(
      'handler' => 'views_handler_field_boolean',
      'output formats' => array(
        'promoted-not-saved' => array(t('Promoted'), t('Not Saved')),
      ),
    ),
    'filter' => array(
      'handler' => 'views_handler_filter_boolean_operator',
      'label' => t('Is Promoted'),
      'type' => 'yes-no',
    ),
  );

  // 3. PROMOTION DATE (The Timestamp)
  $data['webformtonode_map']['created'] = array(
    'title' => t('Promotion Date'),
    'help' => t('The date and time the submission was promoted.'),
    'field' => array(
      'handler' => 'views_handler_field_date',
      'click sortable' => TRUE,
    ),
    'sort' => array('handler' => 'views_handler_sort_date'),
    'filter' => array('handler' => 'views_handler_filter_date'),
  );

  // 4. SUBMISSION ID (The Bridge)
  $data['webformtonode_map']['sid'] = array(
    'title' => t('Map: Submission ID'),
    'help' => t('The original submission ID in our map table.'),
    'field' => array('handler' => 'views_handler_field_numeric'),
  );

  return $data;
}

/**
 * Global AJAX callback to close the standard Backdrop modal.
 */
function webformtonode_ajax_close_modal($form, $form_state) {
  $commands = array();
  $commands[] = ajax_command_close_dialog('#backdrop-modal');
  return array('#type' => 'ajax', '#commands' => $commands);
}

/**
 * Helpers (Files, Augment, Targets)
 */
function _webformtonode_copy_file($fid, $node, $field_name) {
  $field = field_info_field($field_name);
  $instance = field_info_instance('node', $field_name, $node->type);
  if (!$field || !$instance) return NULL;
  if (is_array($fid)) { $fid = reset($fid); }
  $file = file_load($fid);
  if (!$file) return NULL;
  $upload_location = file_field_widget_uri($field, $instance);
  file_prepare_directory($upload_location, FILE_CREATE_DIRECTORY);
  $new_file = file_copy($file, $upload_location . '/' . $file->filename, FILE_EXISTS_RENAME);
  if ($new_file) {
    $new_file->status = FILE_STATUS_PERMANENT;
    file_save($new_file);
    return $new_file->fid;
  }
  return NULL;
}

function webformtonode_augment_submission(&$submission) {
  $node = node_load($submission->nid);
  $form_keys = array();
  foreach ($node->webform['components'] as $cid => $component) { $form_keys[$cid] = $component['form_key']; }
  $submission->keyed_data = array();
  foreach ($submission->data as $cid => $values) {
    if (isset($form_keys[$cid])) { $submission->keyed_data[$form_keys[$cid]] = $values; }
  }
}

function webformtonode_get_target_fields($node_type) {
  $targets = array('title' => t('Node: Title'), 'body' => t('Node: Body'));
  $instances = field_info_instances('node', $node_type);
  foreach ($instances as $field_name => $instance) { $targets[$field_name] = $instance['label'] . ' (' . $field_name . ')'; }
  return $targets;
}
