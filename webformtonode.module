/**
 * Provide a list of actions that can be executed on a submission.
 *
 * Some actions are displayed in the list of submissions such as edit, view, and
 * delete. All other actions are displayed only when viewing the submission.
 * These additional actions may be specified in this hook. Examples included
 * directly in the Webform module include PDF, print, and resend e-mails. Other
 * modules may extend this list by using this hook.
 *
 * @param $node
 *   The Webform node on which this submission was made.
 * @param $submission
 *   The Webform submission on which the actions may be performed.
 *
 * @return array
 *   List of action.
 */
function webformtonode_webform_submission_actions($node, $submission) {

  //Get list of webforms the 'Webform To Node' option should be added to.
  $webformstonode = config_get('webformtonode.settings', 'webforms');

  $actions = array();

  if (webform_results_access($node)) {
    //if this submission nid is in the list of webforms then add button option
    if (in_array($node->nid, $webformstonode, true)) {
       $actions['saveasnode'] = array(
        'title' => t('Save submission as node'),
        'href' => 'node/' . $node->nid . '/submission/' . $submission->sid . '/saveasnode',
       'query' => backdrop_get_destination(),
     );
    }
  }

  //backdrop_set_message('<pre>$actions - $actions<br>'. print_r($actions, TRUE) .'</pre>');

  return $actions;
}


/**
* Form confirming to create a new node from form submissoin
*/
function webformtonode_confirm($form, $form_state, $node, $submission) {

  backdrop_set_message('<pre>$submission - $submission<br>'. print_r($submission, TRUE) .'</pre>');

  // Get name of submitter.
  $speaker_name = $submission->data[1][0];

  backdrop_set_message('<pre>$speaker_name - $speaker_name<br>'. print_r($speaker_name, TRUE) .'</pre>');

  $form['#tree'] = TRUE;

  $form['#node'] = $node;
  $form['#submission'] = $submission;
  $form['actions'] = array('#type' => 'actions');
  $form['actions']['text'] = array('#markup' => '<p>' . t('Are you sure you want to create a new node from <strong><em>' . $speaker_name . '</em></strong> submission?') . '</p>');
  $form['actions']['save'] = array(
    '#type' => 'submit',
    '#value' => t('Create node from submission'),
  );
  $form['actions']['cancel'] = array(
    '#type' => 'markup',
    '#markup' => l(t('Cancel'), isset($_GET['destination']) ? $_GET['destination'] : 'node/' . $node->nid . '/saveasnode/' . $submission->sid),
  );
return $form;
}

/**
 * Submit function for creating a node from a webform submission.
 */
function webformtonode_confirm_submit($form, &$form_state) {
  // 1. Retrieve the objects from the form arguments.
  // $node is the Webform node; $submission is the user's data.
  $webform_node = $form_state['build_info']['args'][0];
  $submission = $form_state['build_info']['args'][1];

  // 2. Load the mapping configuration for this specific Webform.
  $config = config('webformtonode.settings');
  $target_type = $config->get('mapping_' . $webform_node->nid . '_type');
  $field_map = $config->get('mapping_' . $webform_node->nid . '_fields');

  if (!$target_type || empty($field_map)) {
    backdrop_set_message(t('No mapping configuration found. Please configure the mapping for this Webform.'), 'error');
    return;
  }

  // 3. Convert numeric CIDs to human-readable 'form_keys' (Augmentation).
  webformtonode_augment_submission($submission);

  // 4. Initialize the new Node entity.
  $new_node = entity_create('node', array('type' => $target_type));
  node_object_prepare($new_node);

  // Standardize settings: Use LANGUAGE_NONE and set author to submitter.
  $new_node->langcode = LANGUAGE_NONE;
  $new_node->uid = $submission->uid;
  $new_node->status = 1; // Default to published for Alpha testing.

  // 5. Loop through the mapping and translate Webform data to Node fields.
  foreach ($field_map as $webform_key => $node_target) {
    // Skip if 'Skip Field' was selected or if the webform key doesn't exist.
    if (empty($node_target) || !isset($submission->keyed_data[$webform_key])) {
      continue;
    }

    $values = $submission->keyed_data[$webform_key];

    // Handle Title and Body separately as they aren't standard Field API fields.
    if ($node_target == 'title') {
      $new_node->title = isset($values[0]) ? $values[0] : '';
    }
    elseif ($node_target == 'body') {
      $new_node->body[LANGUAGE_NONE][0]['value'] = isset($values[0]) ? $values[0] : '';
      $new_node->body[LANGUAGE_NONE][0]['format'] = 'filtered_html';
    }
    else {
      // Logic for standard and multi-value fields.
      $field_info = field_info_field($node_target);

      // Identify the correct database column for this field type.
      $column = 'value';
      if (isset($field_info['type'])) {
        switch ($field_info['type']) {
          case 'email': $column = 'email'; break;
          case 'link_field': $column = 'url'; break;
          case 'taxonomy_term_reference': $column = 'tid'; break;
          case 'file':
          case 'image': $column = 'fid'; break;
        }
      }

      // Initialize the field array to prevent "ghost" data if overwriting.
      $new_node->{$node_target}[LANGUAGE_NONE] = array();

      // Loop through all values (handles single items and multi-checkboxes).
      foreach ($values as $delta => $val) {
        if ($val !== '') {
          $new_node->{$node_target}[LANGUAGE_NONE][$delta][$column] = $val;
        }
      }
    }
  }

  // 6. Final safety check: Nodes REQUIRE a title.
  // If no title was mapped, use a fallback (Auto Title module may overwrite this later).
  if (empty($new_node->title)) {
    $new_node->title = t('Submission @sid from @form', array(
      '@sid' => $submission->sid,
      '@form' => $webform_node->title
    ));
  }

  // 7. Save the node and provide feedback.
  node_save($new_node);

  backdrop_set_message(t('Successfully created @type: !link', array(
    '@type' => $target_type,
    '!link' => l($new_node->title, 'node/' . $new_node->nid)
  )));

  // Redirect the administrator to the new content.
  $form_state['redirect'] = 'node/' . $new_node->nid;
}

/**
 * Returns a list of mappable targets for a specific content type.
 * Includes the Node Title, Body, and all Field API fields.
 */
function webformtonode_get_target_fields($node_type) {
  $targets = array(
    'title' => t('Node: Title'),
    'body' => t('Node: Body'),
  );

  // Get all field instances for this specific node bundle.
  $instances = field_info_instances('node', $node_type);

  foreach ($instances as $field_name => $instance) {
    // We display the Label and the machine name for clarity (Feeds style).
    $targets[$field_name] = $instance['label'] . ' (' . $field_name . ')';
  }

  return $targets;
}

/**
 * Augment a webform submission with a list of keyed data.
 * This allows us to access data via 'form_key' instead of 'cid'.
 */
function webformtonode_augment_submission(&$submission) {
  $node = node_load($submission->nid);
  if (empty($node) || $node->type != 'webform') {
    return;
  }

  // Map cid to form_key.
  $form_keys = array();
  foreach ($node->webform['components'] as $cid => $component) {
    $form_keys[$cid] = $component['form_key'];
  }

  $submission->keyed_data = array();
  foreach ($submission->data as $cid => $values) {
    // Webform data is always an array of values (for multi-selects, etc).
    // We store the whole array in keyed_data.
    $submission->keyed_data[$form_keys[$cid]] = $values;
  }
}
