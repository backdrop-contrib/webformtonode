/**
 * Implementation of hook_preprocess().
 *
 * This will add the css file to every page
 */
function webformtonode_preprocess(&$vars, $hook) {
  if($hook == 'page')
   backdrop_add_css(backdrop_get_path('module', 'webformtonode') .'/css/webformtonode.css');
}


